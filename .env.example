# 复制到 /etc/auth-gate.env。建议用 `auth-gate genenv <密码>` 自动生成（含密码哈希与随机 secret）。
GATE_HOST=127.0.0.1
GATE_PORT=3001
GATE_COOKIE_NAME=__Secure-session
# 设为父域可实现跨子域 SSO（如 example.com）；留空则仅当前主机
GATE_COOKIE_DOMAIN=
GATE_LOGIN_PATH=/_auth
GATE_SESSION_TTL=15552000
GATE_TITLE=Login
GATE_PASSWORD_HASH=pbkdf2_sha256$260000$replace_with_salt$replace_with_hash
GATE_SECRET=replace_with_random_secret
