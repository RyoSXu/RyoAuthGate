# 把受保护服务接入统一登录的可复用片段。
# 用法：在站点块里 `import protected 127.0.0.1:<后端端口>`。
# 未登录的请求会被网关拦到登录页；登录后会话 Cookie 设在父域，覆盖所有子域。

(protected) {
	# 登录/登出等页面（网关本身，免鉴权）
	handle_path /_auth/* {
		reverse_proxy 127.0.0.1:3001
	}
	# 其余请求先经网关鉴权，再回源到后端
	handle {
		forward_auth 127.0.0.1:3001 {
			uri /verify
			header_up X-Original-URI {uri}
		}
		reverse_proxy {args[0]}
	}
}

# 部分后端（如 PairDrop）不希望收到 forward_auth 带来的 Authorization 头
(protected-drop) {
	handle_path /_auth/* {
		reverse_proxy 127.0.0.1:3001
	}
	handle {
		forward_auth 127.0.0.1:3001 {
			uri /verify
			header_up X-Original-URI {uri}
		}
		reverse_proxy {args[0]} {
			header_up -Authorization
		}
	}
}

# 示例：简单站点，全部走统一登录
app.example.com {
	import protected 127.0.0.1:8080
}

# 示例：PWA 图标 / manifest 需免登录，其余仍走统一登录
tools.example.com {
	@public_icons path /site.webmanifest /favicon.ico /favicon.svg /apple-touch-icon.png
	handle @public_icons {
		reverse_proxy 127.0.0.1:8092
	}
	import protected 127.0.0.1:8092
}

# 示例：图标免登录 + 后端需剥离 Authorization（PairDrop 等）
drop.example.com {
	@public_icons path /manifest.json /images/apple-touch-icon.png /images/favicon-96x96.png
	handle @public_icons {
		reverse_proxy 127.0.0.1:3000
	}
	import protected-drop 127.0.0.1:3000
}

# 自带登录的服务不要 import protected，保持原样即可：
# files.example.com {
# 	reverse_proxy 127.0.0.1:5244
# }
